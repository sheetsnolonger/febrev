<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<header>
  <h1>feb & rev</h1>
  <p>sister & brother</p>
  <nav>
    <a href="/">shop</a>
  </nav>
</header>

<main>
  <section class="hero">
    <h2>handmade crochet & knitted items</h2>
    <p>browse our catalog below.</p>
  </section>

  <section class="grid">
    <% products.forEach(product => { %>
      <div class="card">
        <img src="<%= product.image %>" alt="<%= product.name %>">
        <h3><%= product.name %></h3>
        <p>$<%= product.price %></p>
        <p><%= product.description %></p>

        <a class="button" href="/product/<%= product.id %>">view item</a>

        <a class="button" href="<%= product.ebay %>" target="_blank" rel="noopener">
          buy on ebay
        </a>
      </div>
    <% }) %>
  </section>
</main>

<footer>
  febrev.shop
</footer>

</body>
</html>
