<!DOCTYPE html>
<html>
<head>
  <title><%= title %> | feb & rev</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<header>
  <h1>feb & rev</h1>
  <nav>
    <a href="/">shop</a>
  </nav>
</header>

<main>
  <div class="product-page">
    <img src="<%= product.image %>" alt="<%= product.name %>">

    <div>
      <h2><%= product.name %></h2>
      <p class="price">$<%= product.price %></p>
      <p><%= product.description %></p>

      <a class="button" href="<%= product.ebay %>" target="_blank" rel="noopener">
        buy on ebay
      </a>
    </div>
  </div>
</main>

<footer>
  febrev.shop
</footer>

</body>
</html>
